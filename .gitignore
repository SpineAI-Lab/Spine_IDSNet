# =============================================================================
# SpineIDS Clinical ML – .gitignore
# =============================================================================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/

# CatBoost training artefacts
catboost_info/

# Trained model checkpoints and large binary outputs
outputs/
*.pkl
*.npy

# Logs
*.log

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# OS artefacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
